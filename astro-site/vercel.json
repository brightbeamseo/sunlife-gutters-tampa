{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "sunlifegutterstampa.com"
        }
      ],
      "destination": "https://www.sunlifegutterstampa.com/$1",
      "permanent": true
    },
    {
      "source": "/city-service-base/",
      "destination": "/products-services/gutter-repair-denver-co/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/)(?!.*\\.).*[^/])",
      "destination": "/:path/",
      "permanent": true
    }
  ],
  "functions": {
    "api/lead.js": {
      "maxDuration": 30
    }
  }
}
