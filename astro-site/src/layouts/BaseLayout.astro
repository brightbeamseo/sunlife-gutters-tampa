---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import '../../styles.css'
import { buildHomeAndConstructionBusinessJsonLd } from '../lib/local-business-json-ld.js'
import { getSiteSettings } from '../lib/site-settings.js'
import { buildThemeCss } from '../lib/theme-css.js'

const { title, description, theme, forms, homeRevealAnimations = false } = Astro.props

const settings = await getSiteSettings()
const localBusinessJsonLd = buildHomeAndConstructionBusinessJsonLd(settings)

if (!forms || typeof forms.submitPath !== 'string' || !forms.submitPath.trim()) {
  throw new Error('BaseLayout: forms.submitPath is required (set from Sanity siteSettings.forms).')
}

const themeCss = buildThemeCss(theme)

const recaptchaSiteKey =
  (import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '').trim() ||
  '6LdBAJgsAAAAAEEaAljBBQUMkyJaEfhw0Bas6ZKL'
const formsForClient = { ...forms, recaptchaSiteKey }
const formsJson = JSON.stringify(formsForClient).replace(/</g, '\\u003c')
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-XXXXXXX');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {localBusinessJsonLd ? (
      <script type="application/ld+json" set:html={localBusinessJsonLd} />
    ) : null}
    <link rel="icon" href="/favicon.png" type="image/png" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/json" id="site-forms-config" set:html={formsJson} />
    {recaptchaSiteKey ? (
      <script
        src={`https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(recaptchaSiteKey)}`}
        async
        defer
      />
    ) : null}
  </head>
  <body class:list={[{ 'home-reveal-animate': homeRevealAnimations }]}>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <!-- After bundled styles.css so :root theme tokens override file defaults -->
    <style id="site-theme-vars" set:html={themeCss}></style>
    <Analytics />
    <SpeedInsights />
    <script src="/script.js" defer></script>
  </body>
</html>
