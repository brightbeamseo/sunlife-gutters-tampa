---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FooterSocialIcon from '../../components/FooterSocialIcon.astro'
import FooterContactInfo from '../../components/FooterContactInfo.astro'
import FooterHoursRow from '../../components/FooterHoursRow.astro'
import { externalLinkAttrs } from '../../lib/external-link.js'
import { googleBusinessProfileUrl, isContactFooterColumnHeading } from '../../lib/footer-contact-heading.js'
import { sanity } from '../../lib/sanity.js'
import { getSiteSettings, getHomePage, mergeHeaderFromSettings } from '../../lib/site-settings.js'
import { heroBackgroundFor } from '../../lib/hero-backgrounds.js'
import { sanitizeCmsHtml } from '../../lib/sanitize-cms-html.js'
import { asStr, applyTemplate, mediaUrl } from '../../lib/sanity-strings.js'

export async function getStaticPaths() {
  try {
    const pages = await sanity.fetch(
      `*[_type == "cityServicePage" && defined(slug.current)]{"slug": slug.current}`
    )
    return (Array.isArray(pages) ? pages : [])
      .map((p) => asStr(p?.slug))
      .filter(Boolean)
      .map((slug) => ({ params: { slug } }))
  } catch (err) {
    console.warn('[services/[slug]] Failed to load city service slugs.', err)
    return []
  }
}

const slug = asStr(Astro.params?.slug)
const pageDescription = 'Professional gutter services in Tampa with fast scheduling and quality workmanship.'

let settings = {}
let homePage = {}
let cityPage = {}
try {
  ;[settings, homePage, cityPage] = await Promise.all([
    getSiteSettings(),
    getHomePage(),
    sanity.fetch(`*[_type == "cityServicePage" && slug.current == $slug][0]`, { slug }),
  ])
} catch (err) {
  console.warn(`[services/${slug}] Sanity fetch failed; using fallback placeholders.`, err)
}

const business = settings?.business ?? {}
const header = mergeHeaderFromSettings(settings, homePage?.header)
const hero = homePage?.hero ?? {}
const services = homePage?.services ?? {}
const faq = cityPage?.faq ?? homePage?.faq ?? {}
const footerEstimate = settings?.footerEstimate ?? homePage?.footerEstimate ?? {}
const footerEstimateFields = footerEstimate?.formFields ?? {}
const formsCfg = settings?.forms ?? {}
const footerBrand = settings?.footerBrand ?? homePage?.footerBrand ?? {}
const footerColumns = settings?.footerColumns ?? homePage?.footerColumns ?? []
const footerSupport = settings?.footerSupport ?? homePage?.footerSupport ?? {}

const companyName = asStr(business.companyName) || 'SGT'
const phoneDisplay = asStr(business.phoneDisplay) || '(303) 000-0000'
const phoneTel = asStr(business.phoneTel) || '3030000000'
const email = asStr(business.email) || 'hello@example.com'
const address = asStr(business.addressShort) || 'Tampa, Colorado'
const addressHref = googleBusinessProfileUrl(settings)
const descriptionShort = asStr(business.descriptionShort)
const logoWhite = asStr(business.logoHorizontalWhite)
const copyrightHref = asStr(business.copyrightSiteUrl) || '#'
const logoBlack = asStr(business.logoHorizontalBlack)

const callLabelNav = applyTemplate(asStr(header.callCtaTemplate), { phoneDisplay }) || phoneDisplay
const logoAriaLabel = applyTemplate(asStr(header.logoAriaLabelTemplate), { companyName }) || companyName
const navItems = Array.isArray(header.navItems) ? header.navItems : []
const heroCallLabel = applyTemplate(asStr(hero?.callCtaTemplate), { phoneDisplay }) || `Call ${phoneDisplay}`
const universalFormFields = footerEstimateFields
const universalFormAction = asStr(formsCfg?.submitPath) || asStr(footerEstimate?.formAction) || '#'
const universalFormMethod = asStr(footerEstimate?.formMethod) || 'post'
const universalFormKicker = asStr(formsCfg?.formKicker) || 'Free Estimate'
const universalFormAriaLabel = asStr(formsCfg?.formAriaLabel) || 'City service lead form'
const universalRequiredIndicator = asStr(formsCfg?.requiredIndicator) || '*'
const universalFormHeading = asStr(footerEstimate?.headline) || 'Get Started Today'
const universalFormIntro = asStr(footerEstimate?.intro) || 'Short placeholder form for layout testing.'
const heroBgSrc = asStr(cityPage?.layoutBackgrounds?.hero?.imageSrc) || heroBackgroundFor(`service-${slug}`)
const servicesBgSrc = asStr(cityPage?.layoutBackgrounds?.services?.imageSrc)
const heroBgStyle = heroBgSrc
  ? `background-image: linear-gradient(135deg, rgba(56, 69, 85, 0.88) 0%, rgba(56, 69, 85, 0.84) 50%, rgba(56, 69, 85, 0.88) 100%), url("${mediaUrl(heroBgSrc)}"); background-size: cover; background-position: center; background-repeat: no-repeat;`
  : undefined
const servicesBgStyle = servicesBgSrc
  ? `background-color: #143980; background-image: linear-gradient(135deg, rgba(20, 57, 128, 0.94) 0%, rgba(26, 74, 158, 0.94) 100%), url("${mediaUrl(servicesBgSrc)}"); background-size: cover; background-position: center; background-repeat: no-repeat;`
  : undefined
const sharedReviews = settings?.reviews ?? homePage?.reviews ?? {}
const reviewsToRender = sharedReviews
const cityContentSections = Array.isArray(cityPage?.contentSections) ? cityPage.contentSections : []
const mapEmbedUrl = asStr(cityPage?.mapEmbedUrl) || asStr(settings?.mapEmbedUrl)
const estimateCtaText = 'Request Estimate'
const estimateCtaHref = '#contact'
const pageH1 = asStr(cityPage?.headline) || asStr(hero?.headline) || 'Gutter Services in Tampa, FL'
const pageTitle = `${pageH1} | SGT`

const serviceHref = (svc) => {
  const explicit = asStr(svc?.href)
  if (explicit) return explicit
  const title = asStr(svc?.title).toLowerCase().trim()
  if (!title) return '/seamless-gutters/'
  const knownSlugs = {
    'seamless gutters': 'seamless-gutters',
    'soffit & fascia': 'soffit-and-fascias',
    'soffit and fascia': 'soffit-and-fascias',
    'super gutters': 'super-gutters',
    'screen rooms & lanais': 'screen-rooms-and-lanais',
    'screen rooms and lanais': 'screen-rooms-and-lanais',
    'underground drainage': 'underground-drainage',
    siding: 'siding',
  }
  if (knownSlugs[title]) return `/${knownSlugs[title]}/`
  const generated = title
    .replace(/&/g, ' and ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
  return `/${generated}/`
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  theme={settings?.theme}
  forms={{ submitPath: asStr(settings?.forms?.submitPath) || '/api/lead' }}
>
  <header class="header">
    <div class="offer-bar">
      <div class="offer-bar-inner">
        <p class="offer-message">
          {asStr(header?.offerBar?.textBeforeDiscount)}
          <strong>{asStr(header?.offerBar?.discountLabel)}</strong>
          {asStr(header?.offerBar?.textAfterDiscount)}
          <a
            href={asStr(header?.offerBar?.ctaHref) || '#contact'}
            class="offer-link"
            {...externalLinkAttrs(asStr(header?.offerBar?.ctaHref) || '#contact')}
          >
            <strong>{asStr(header?.offerBar?.ctaText) || 'Get a Quote Now!'}</strong>
          </a>
        </p>
      </div>
    </div>
    <div class="header-nav">
      <div class="header-inner">
        <a href="/" class="logo" aria-label={logoAriaLabel}>
          {logoBlack ? (
            <img src={mediaUrl(logoBlack)} alt={companyName} class="logo-img" />
          ) : (
            <span class="section-title" style="margin:0; font-size: 1.25rem;">{companyName}</span>
          )}
        </a>
        <button class="nav-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav">
          {navItems.length > 0 ? (
            navItems.map((item, i) => {
              const label = asStr(item.label)
              const href = asStr(item.href)
              const dropdown = item.dropdown
              if (Array.isArray(dropdown) && dropdown.length > 0) {
                const ddId = `city-nav-dd-${i}`
                return (
                  <div class="nav-dropdown" data-nav-dropdown>
                    <button
                      type="button"
                      class="nav-dropdown-toggle"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={ddId}
                      id={`${ddId}-btn`}
                    >
                      {label}
                      <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                    </button>
                    <ul class="nav-dropdown-menu" id={ddId} role="menu">
                      {dropdown.map((link) => (
                        <li role="none">
                          <a href={asStr(link.href)} role="menuitem" {...externalLinkAttrs(asStr(link.href))}>
                            {asStr(link.label)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
              return (
                <a href={href || '#'} {...externalLinkAttrs(href || '')}>
                  {label}
                </a>
              )
            })
          ) : (
            <>
              <a href="/">Home</a>
              <a href="/seamless-gutters/">Products & Services</a>
            </>
          )}
          <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg">{callLabelNav}</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-split">
      <div class="hero-bg" style={heroBgStyle}></div>
      <div class="container hero-split-inner">
        <div class="hero-copy">
          <div class="hero-eyebrow">{asStr(cityPage?.eyebrow) || asStr(hero?.eyebrow) || 'City Service'}</div>
          <h1>{pageH1}</h1>
          <p class="hero-lead">{asStr(cityPage?.lead) || asStr(hero?.lead) || 'City service page starter connected to Sanity content.'}</p>
          <div class="hero-actions">
            <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg cta1-primary-call">{heroCallLabel}</a>
          </div>
        </div>

        <form
          class="hero-form"
          data-lead-form="city-hero"
          action={universalFormAction}
          method={universalFormMethod}
          aria-label={universalFormAriaLabel}
        >
          <div class="hero-form-heading">
            <div class="hero-form-kicker">{universalFormKicker}</div>
            <h2>{universalFormHeading}</h2>
          </div>
          <p class="hero-form-sub">{universalFormIntro}</p>
          <div class="hero-form-grid">
            <div class="hero-form-field">
              <label for="name">
                {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id="name" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="hero-form-field">
              <label for="email">
                {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id="email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="hero-form-field">
              <label for="phone">
                {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id="phone" name="phone" type="tel" required autocomplete="tel" />
            </div>
            <div class="hero-form-field">
              <label for="location">{asStr(universalFormFields?.cityLabel) || 'City'}</label>
              <input id="location" name="location" type="text" autocomplete="address-level2" />
            </div>
            <div class="hero-form-field hero-form-field-full">
              <label for="message">{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
              <textarea id="message" name="message" rows="3"></textarea>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">{asStr(universalFormFields?.submitButton) || 'Send'}</button>
        </form>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <article style="max-width: 72ch; margin: 0 auto;">
          {(cityContentSections.length > 0
            ? cityContentSections
            : [
                {
                  heading: 'City-Specific Gutter Service Content',
                  body: 'Use this section for rich local service copy. Add one or more blocks in Sanity. Images are optional per block.',
                },
              ]
          ).map((sec) => (
            <>
              {asStr(sec.imageSrc) ? (
                <img
                  src={mediaUrl(asStr(sec.imageSrc))}
                  alt={asStr(sec.imageAlt) || asStr(sec.heading)}
                  style="width: 100%; height: auto; border-radius: 12px; margin: 0 0 1.25rem; display: block;"
                />
              ) : null}
              <h2 class="section-title section-title-secondary">{asStr(sec.heading)}</h2>
              <div
                class="section-lead"
                style="max-width:72ch; white-space: pre-line; margin-bottom: 1rem;"
                set:html={sanitizeCmsHtml(asStr(sec.body))}
              />
              <div class="why-choose-actions" style="margin: 0 0 2.25rem;">
                <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg">{heroCallLabel}</a>
                <a
                  href={estimateCtaHref}
                  class="btn btn-outline btn-lg request-estimate"
                  {...externalLinkAttrs(estimateCtaHref)}
                >
                  {estimateCtaText}
                </a>
              </div>
            </>
          ))}
        </article>
      </div>
    </section>

    <section class="section services" style={servicesBgStyle}>
      <div class="container">
        <h2 class="section-title">{asStr(services?.headline) || 'Our Gutter Services in Tampa'}</h2>
        <div class="services-grid">
          {(Array.isArray(services?.items) && services.items.length > 0
            ? services.items
            : [
                { number: '01', title: 'Gutter Installation', description: 'Placeholder text for service summary.' },
                { number: '02', title: 'Gutter Repair', description: 'Placeholder text for service summary.' },
                { number: '03', title: 'Gutter Guards', description: 'Placeholder text for service summary.' },
              ]
          ).map((svc) => (
            <article class="service-card">
              <a href={serviceHref(svc)} class="service-image-wrap" style="display:block; color:inherit; text-decoration:none;">
                <span class="service-number">{asStr(svc.number)}</span>
                <h3 class="service-title">{asStr(svc.title)}</h3>
                <p class="service-desc">{asStr(svc.description)}</p>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section faq-section" id="faq">
      <div class="container">
        <div class="faq-panel">
          <h2 class="section-title section-title-secondary" id={asStr(faq?.headingId) || 'city-faq-heading'}>
            {asStr(faq?.headline) || 'Frequently Asked Questions'}
          </h2>
          <div class="faq-list" data-faq-accordion>
            {(Array.isArray(faq?.items) && faq.items.length > 0
              ? faq.items
              : [
                  {
                    question: 'How long does installation take?',
                    answerHtml: '<p>Most projects are completed in one day depending on roof size and complexity.</p>',
                  },
                ]
            ).slice(0, 8).map((item, idx) => {
              const n = idx + 1
              const btnId = `city-faq-btn-${n}`
              const panelId = `city-faq-panel-${n}`
              return (
                <div class="faq-item">
                  <button
                    type="button"
                    class="faq-summary"
                    id={btnId}
                    aria-expanded="false"
                    aria-controls={panelId}
                  >
                    <span class="faq-question">{asStr(item.question)}</span>
                    <span class="faq-chevron" aria-hidden="true"></span>
                  </button>
                  <div
                    class="faq-answer-outer"
                    id={panelId}
                    role="region"
                    aria-labelledby={btnId}
                    aria-hidden="true"
                  >
                    <div class="faq-answer" set:html={sanitizeCmsHtml(asStr(item.answerHtml))} />
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      </div>
    </section>

    <section class="section google-reviews">
      <div class="container">
        <h2 class="section-title reviews-title">{asStr(reviewsToRender?.headline) || 'Customer Reviews'}</h2>
        <div class="reviews-summary">
          <div class="reviews-summary-left">
            <p class="reviews-summary-brand">
              <img
                src={mediaUrl(asStr(reviewsToRender?.summary?.googleIconSrc))}
                alt={asStr(reviewsToRender?.summary?.brandLabel)}
                class="google-logo"
              />
              <span>{asStr(reviewsToRender?.summary?.brandLabel)}</span>
            </p>
          </div>
          <a
            href={asStr(reviewsToRender?.summary?.ctaHref) || '/reviews/'}
            class="btn btn-primary reviews-summary-cta"
            {...externalLinkAttrs(asStr(reviewsToRender?.summary?.ctaHref) || '/reviews/')}
          >
            {asStr(reviewsToRender?.summary?.ctaText) || 'See More Reviews'}
          </a>
        </div>
        <div class="testimonials-grid">
          {(Array.isArray(reviewsToRender?.testimonials) ? reviewsToRender.testimonials : []).slice(0, 4).map((t) => (
            <blockquote class="testimonial">
              <div class="review-brand review-brand-top">
                <img src={mediaUrl(asStr(t.avatarSrc))} alt={asStr(t.author)} class="review-avatar" />
                <div class="review-meta">
                  <strong>{asStr(t.author)}</strong>
                  <span class="review-time">{asStr(t.timeAgo)}</span>
                </div>
              </div>
              <img
                src={mediaUrl(asStr(reviewsToRender?.summary?.starsImageSrc))}
                alt={asStr(reviewsToRender?.summary?.starsImageAlt)}
                class="review-stars"
              />
              <p>&quot;{asStr(t.quote)}&quot;</p>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <section class="section service-area" id="city-map">
      <div class="map-wrap" style="max-width: none; border-radius: 0; box-shadow: none;">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="440"
          style="border:0; display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`${companyName} service area map`}
        ></iframe>
      </div>
    </section>
  </main>

  <footer class="footer">
    <section id="contact" class="section contact footer-estimate">
      <div class="container">
        <div class="contact-wrapper">
          <div class="contact-info">
            <h2 class="section-title">{asStr(footerEstimate?.headline) || 'Need Gutter Help in Tampa?'}</h2>
            <p>{asStr(footerEstimate?.intro) || 'Placeholder contact block for the City Service page base.'}</p>
            <FooterContactInfo
              variant="estimate"
              phoneTel={phoneTel}
              phoneDisplay={phoneDisplay}
              email={email}
              address={address}
              addressHref={addressHref}
            />
          </div>
          <form
            class="contact-form"
            data-lead-form="city-footer"
            action={universalFormAction}
            method={universalFormMethod}
          >
            <div class="contact-form-grid">
              <div class="contact-form-field">
                <label for="contact-name">
                  {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id="contact-name" name="name" type="text" required autocomplete="name" />
              </div>
              <div class="contact-form-field">
                <label for="contact-email">
                  {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id="contact-email" name="email" type="email" required autocomplete="email" />
              </div>
              <div class="contact-form-field">
                <label for="contact-phone">
                  {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id="contact-phone" name="phone" type="tel" required autocomplete="tel" />
              </div>
              <div class="contact-form-field">
                <label for="contact-location">{asStr(universalFormFields?.cityLabel) || 'City'}</label>
                <input id="contact-location" name="location" type="text" autocomplete="address-level2" />
              </div>
              <div class="contact-form-field contact-form-field-full">
                <label for="contact-message">{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
                <textarea id="contact-message" name="message" rows="4"></textarea>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">{asStr(footerEstimateFields?.submitButton) || 'Request Quote'}</button>
          </form>
        </div>
      </div>
    </section>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand-block footer-col">
          {logoWhite ? <img src={mediaUrl(logoWhite)} alt={companyName} class="footer-logo" /> : null}
          <p class="footer-address">{descriptionShort}</p>
          <div class="footer-social" aria-label={asStr(footerBrand?.socialAriaLabel)}>
            {footerBrand?.socialLinks?.map((s) => (
              <a href={asStr(s.href)} aria-label={asStr(s.ariaLabel)} {...externalLinkAttrs(asStr(s.href))}>
                <FooterSocialIcon platform={asStr(s.platform)} />
              </a>
            ))}
          </div>
        </div>
        {footerColumns?.map((col) => (
          <div class="footer-col">
            <p class="footer-heading">{asStr(col.heading)}</p>
            {col.links?.length ? (
              <nav class="footer-links" aria-label={asStr(col.ariaLabel)}>
                {col.links.map((link) => (
                  <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
                    {asStr(link.label)}
                  </a>
                ))}
              </nav>
            ) : null}
            {isContactFooterColumnHeading(col.heading) ? (
              <FooterContactInfo
                variant="footer-column"
                phoneTel={phoneTel}
                phoneDisplay={phoneDisplay}
                email={email}
                address={address}
                addressHref={addressHref}
              />
            ) : null}
            {col.hoursHeading ? <p class="footer-heading footer-hours-heading">{asStr(col.hoursHeading)}</p> : null}
            {col.hoursText ? <FooterHoursRow hoursText={col.hoursText} /> : null}
          </div>
        ))}
      </div>
    </div>
  </footer>

  <div class="footer-support">
    <div class="container footer-support-inner">
      <p>
        © <span id="year"></span> —{' '}
        <a href={copyrightHref} {...externalLinkAttrs(copyrightHref)}>
          {companyName}
        </a>
      </p>
      <nav aria-label={asStr(footerSupport?.ariaLabel)}>
        {footerSupport?.links?.map((link) => (
          <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
            {asStr(link.label)}
          </a>
        ))}
      </nav>
    </div>
  </div>
</BaseLayout>
