---
/**
 * Root-level blog posts: /{slug}/ (e.g. /blog-topic-slug/).
 * Only generates paths for Sanity `blogPost` documents — static routes (about-us, contact-us, …) win.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import FooterSocialIcon from '../components/FooterSocialIcon.astro'
import FooterContactInfo from '../components/FooterContactInfo.astro'
import FooterHoursRow from '../components/FooterHoursRow.astro'
import { googleBusinessProfileUrl, isContactFooterColumnHeading } from '../lib/footer-contact-heading.js'
import { sanity } from '../lib/sanity.js'
import { getSiteSettings, mergeHeaderFromSettings } from '../lib/site-settings.js'
import { heroBackgroundFor } from '../lib/hero-backgrounds.js'
import { sanitizeCmsHtml } from '../lib/sanitize-cms-html.js'
import { asStr, applyTemplate, mediaUrl } from '../lib/sanity-strings.js'

export async function getStaticPaths() {
  try {
    const rows = await sanity.fetch(`*[_type == "blogPost" && defined(slug.current)]{"slug": slug.current}`)
    const slugs = (Array.isArray(rows) ? rows : []).map((r) => asStr(r?.slug)).filter(Boolean)
    return slugs.map((slug) => ({ params: { slug } }))
  } catch (err) {
    console.warn('[blog slug] Failed to load blog post slugs.', err)
    return []
  }
}

const slug = asStr(Astro.params?.slug)

let settings = {}
let homePage = {}
let post = null
try {
  ;[settings, homePage, post] = await Promise.all([
    getSiteSettings(),
    sanity.fetch(`*[_type == "homePage"][0]`),
    sanity.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, { slug }),
  ])
} catch (err) {
  console.warn(`[blog/${slug}] Sanity fetch failed.`, err)
}

if (!post) {
  throw new Error(`[blog] Missing blogPost for slug "${slug}"`)
}

const business = settings?.business ?? {}
const header = mergeHeaderFromSettings(settings, homePage?.header)
const footerEstimate = settings?.footerEstimate ?? homePage?.footerEstimate ?? {}
const footerEstimateFields = footerEstimate?.formFields ?? {}
const formsCfg = settings?.forms ?? {}
const footerBrand = settings?.footerBrand ?? homePage?.footerBrand ?? {}
const footerColumns = settings?.footerColumns ?? homePage?.footerColumns ?? []
const footerSupport = settings?.footerSupport ?? homePage?.footerSupport ?? {}

const companyName = asStr(business.companyName) || 'SunLife Gutters Tampas'
const phoneDisplay = asStr(business.phoneDisplay) || '(303) 000-0000'
const phoneTel = asStr(business.phoneTel) || '3030000000'
const email = asStr(business.email) || 'hello@example.com'
const address = asStr(business.addressShort) || 'Tampa, Colorado'
const addressHref = googleBusinessProfileUrl(settings)
const descriptionShort = asStr(business.descriptionShort)
const logoWhite = asStr(business.logoHorizontalWhite)
const logoBlack = asStr(business.logoHorizontalBlack)
const copyrightHref = asStr(business.copyrightSiteUrl) || '#'

const pageTitle = asStr(post?.meta?.title) || `${asStr(post?.headline)} | SunLife Gutters Tampas`
const pageDescription = asStr(post?.meta?.description) || asStr(post?.lead) || 'Article from SunLife Gutters Tampa Tampa.'
const callLabelNav = applyTemplate(asStr(header.callCtaTemplate), { phoneDisplay }) || phoneDisplay
const logoAriaLabel = applyTemplate(asStr(header.logoAriaLabelTemplate), { companyName }) || companyName
const navItems = Array.isArray(header.navItems) ? header.navItems : []

const universalFormFields = footerEstimateFields
const universalFormAction = asStr(formsCfg?.submitPath) || asStr(footerEstimate?.formAction) || '#'
const universalFormMethod = asStr(footerEstimate?.formMethod) || 'post'
const universalFormKicker = asStr(formsCfg?.formKicker) || 'Free Estimate'
const universalFormAriaLabel = asStr(formsCfg?.formAriaLabel) || 'Blog lead form'
const universalRequiredIndicator = asStr(formsCfg?.requiredIndicator) || '*'
const universalFormHeading = asStr(footerEstimate?.headline) || 'Get Started Today'
const universalFormIntro = asStr(footerEstimate?.intro) || 'Short placeholder form for layout testing.'

const heroBgSrc =
  asStr(post?.layoutBackgrounds?.hero?.imageSrc) || heroBackgroundFor(`blog-${slug}`)
const heroBgStyle = heroBgSrc
  ? `background-image: linear-gradient(135deg, rgba(56, 69, 85, 0.88) 0%, rgba(56, 69, 85, 0.84) 50%, rgba(56, 69, 85, 0.88) 100%), url("${mediaUrl(heroBgSrc)}"); background-size: cover; background-position: center; background-repeat: no-repeat;`
  : undefined

const heroHeadline = asStr(post?.headline) || 'Article'
const postCategory = asStr(post?.category)
const postTldr = asStr(post?.tldr) || asStr(post?.lead)
const contentSections = Array.isArray(post?.contentSections) ? post.contentSections : []

function formatBlogPostDate(iso) {
  if (!iso || typeof iso !== 'string') return ''
  const d = new Date(iso)
  if (Number.isNaN(d.getTime())) return ''
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

/** Prefer Sanity system _updatedAt; fall back to publishedAt. */
const lastUpdatedRaw = asStr(post?._updatedAt) || asStr(post?.publishedAt)
const lastUpdatedLabel = formatBlogPostDate(lastUpdatedRaw)

const blogAuthorBio =
  asStr(settings?.blogAuthorBio) ||
  `${asStr(business.companyNameShort) || companyName} is a family-owned Tampa gutter company with decades of experience in installation, repair, replacement, and gutter guards across the Front Range.`

const idPrefix = `blog-${slug.replace(/[^a-z0-9-]/gi, '_')}`
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  theme={settings?.theme}
  forms={{ submitPath: asStr(settings?.forms?.submitPath) || '/api/lead' }}
>
  <header class="header">
    <div class="offer-bar">
      <div class="offer-bar-inner">
        <p class="offer-message">
          {asStr(header?.offerBar?.textBeforeDiscount)}
          <strong>{asStr(header?.offerBar?.discountLabel)}</strong>
          {asStr(header?.offerBar?.textAfterDiscount)}
          <a href={asStr(header?.offerBar?.ctaHref) || '#contact'} class="offer-link">
            <strong>{asStr(header?.offerBar?.ctaText) || 'Get a Quote Now!'}</strong>
          </a>
        </p>
      </div>
    </div>
    <div class="header-nav">
      <div class="header-inner">
        <a href="/" class="logo" aria-label={logoAriaLabel}>
          {logoBlack ? <img src={mediaUrl(logoBlack)} alt={companyName} class="logo-img" /> : <span class="section-title" style="margin:0; font-size: 1.25rem;">{companyName}</span>}
        </a>
        <button class="nav-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav">
          {navItems.length > 0 ? (
            navItems.map((item, i) => {
              const label = asStr(item.label)
              const href = asStr(item.href)
              const dropdown = item.dropdown
              if (Array.isArray(dropdown) && dropdown.length > 0) {
                const ddId = `${idPrefix}-nav-dd-${i}`
                return (
                  <div class="nav-dropdown" data-nav-dropdown>
                    <button
                      type="button"
                      class="nav-dropdown-toggle"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={ddId}
                      id={`${ddId}-btn`}
                    >
                      {label}
                      <span class="nav-dropdown-chevron" aria-hidden="true" />
                    </button>
                    <ul class="nav-dropdown-menu" id={ddId} role="menu">
                      {dropdown.map((link) => (
                        <li role="none">
                          <a href={asStr(link.href)} role="menuitem">
                            {asStr(link.label)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
              return <a href={href || '#'}>{label}</a>
            })
          ) : (
            <>
              <a href="/">Home</a>
              <a href="/products-services/">Products & Services</a>
            </>
          )}
          <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg">{callLabelNav}</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-split blog-post-hero" aria-label="Article">
      <div class="hero-bg" style={heroBgStyle} />
      <div class="container hero-split-inner">
        <div class="hero-copy">
          {postCategory ? <p class="hero-eyebrow">{postCategory}</p> : null}
          <h1>{heroHeadline}</h1>
          {postTldr ? (
            <p class="hero-lead">
              <strong>TLDR;</strong> {postTldr}
            </p>
          ) : null}
        </div>
        <form
          class="hero-form"
          data-lead-form={`blog-hero-${slug}`}
          action={universalFormAction}
          method={universalFormMethod}
          aria-label={universalFormAriaLabel}
        >
          <div class="hero-form-heading">
            <div class="hero-form-kicker">{universalFormKicker}</div>
            <h2>{universalFormHeading}</h2>
          </div>
          <p class="hero-form-sub">{universalFormIntro}</p>
          <div class="hero-form-grid">
            <div class="hero-form-field">
              <label for={`${idPrefix}-name`}>
                {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${idPrefix}-name`} name="name" type="text" required autocomplete="name" />
            </div>
            <div class="hero-form-field">
              <label for={`${idPrefix}-email`}>
                {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${idPrefix}-email`} name="email" type="email" required autocomplete="email" />
            </div>
            <div class="hero-form-field">
              <label for={`${idPrefix}-phone`}>
                {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${idPrefix}-phone`} name="phone" type="tel" required autocomplete="tel" />
            </div>
            <div class="hero-form-field">
              <label for={`${idPrefix}-location`}>{asStr(universalFormFields?.cityLabel) || 'City'}</label>
              <input id={`${idPrefix}-location`} name="location" type="text" autocomplete="address-level2" />
            </div>
            <div class="hero-form-field hero-form-field-full">
              <label for={`${idPrefix}-message`}>{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
              <textarea id={`${idPrefix}-message`} name="message" rows="3" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">{asStr(universalFormFields?.submitButton) || 'Send'}</button>
        </form>
      </div>
    </section>

    <section class="section blog-post">
      <div class="container">
        <article class="blog-post-article">
          <div class="blog-post-inner">
            {contentSections.map((sec) => (
              <div class="blog-post-block">
                {asStr(sec.imageSrc) ? (
                  <img
                    src={mediaUrl(asStr(sec.imageSrc))}
                    alt={asStr(sec.imageAlt) || asStr(sec.heading)}
                    class="blog-post-image"
                    loading="lazy"
                    decoding="async"
                  />
                ) : null}
                <h2 class="section-title section-title-secondary">{asStr(sec.heading)}</h2>
                <div
                  class="blog-post-body prose-plain"
                  style="white-space: pre-line;"
                  set:html={sanitizeCmsHtml(asStr(sec.body))}
                />
              </div>
            ))}
          </div>

          {lastUpdatedLabel ? (
            <p class="blog-post-updated">
              Last updated: <time datetime={lastUpdatedRaw}>{lastUpdatedLabel}</time>
            </p>
          ) : null}

          <aside class="blog-author-card" aria-labelledby="blog-author-heading">
            <div class="blog-author-inner">
              {logoBlack ? (
                <img src={mediaUrl(logoBlack)} alt="" class="blog-author-logo" width="180" height="48" loading="lazy" />
              ) : null}
              <h2 class="blog-author-heading" id="blog-author-heading">About the author</h2>
              <p class="blog-author-name">{companyName}</p>
              <p class="blog-author-bio">{blogAuthorBio}</p>
            </div>
          </aside>
        </article>
      </div>
    </section>
  </main>

  <footer class="footer">
    <section id="contact" class="section contact footer-estimate">
      <div class="container">
        <div class="contact-wrapper">
          <div class="contact-info">
            <h2 class="section-title">{asStr(footerEstimate?.headline) || 'Need Gutter Help in Tampa?'}</h2>
            <p>{asStr(footerEstimate?.intro) || 'Contact us for fast service and straightforward estimates.'}</p>
            <FooterContactInfo variant="estimate" phoneTel={phoneTel} phoneDisplay={phoneDisplay} email={email} address={address} addressHref={addressHref} />
          </div>
          <form class="contact-form" data-lead-form={`blog-footer-${slug}`} action={universalFormAction} method={universalFormMethod}>
            <div class="contact-form-grid">
              <div class="contact-form-field">
                <label for={`${idPrefix}-contact-name`}>
                  {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${idPrefix}-contact-name`} name="name" type="text" required autocomplete="name" />
              </div>
              <div class="contact-form-field">
                <label for={`${idPrefix}-contact-email`}>
                  {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${idPrefix}-contact-email`} name="email" type="email" required autocomplete="email" />
              </div>
              <div class="contact-form-field">
                <label for={`${idPrefix}-contact-phone`}>
                  {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${idPrefix}-contact-phone`} name="phone" type="tel" required autocomplete="tel" />
              </div>
              <div class="contact-form-field">
                <label for={`${idPrefix}-contact-location`}>{asStr(universalFormFields?.cityLabel) || 'City'}</label>
                <input id={`${idPrefix}-contact-location`} name="location" type="text" autocomplete="address-level2" />
              </div>
              <div class="contact-form-field contact-form-field-full">
                <label for={`${idPrefix}-contact-message`}>{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
                <textarea id={`${idPrefix}-contact-message`} name="message" rows="4" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">{asStr(footerEstimateFields?.submitButton) || 'Request Quote'}</button>
          </form>
        </div>
      </div>
    </section>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand-block footer-col">
          {logoWhite ? <img src={mediaUrl(logoWhite)} alt={companyName} class="footer-logo" /> : null}
          <p class="footer-address">{descriptionShort}</p>
          <div class="footer-social" aria-label={asStr(footerBrand?.socialAriaLabel)}>
            {footerBrand?.socialLinks?.map((s) => (
              <a href={asStr(s.href)} aria-label={asStr(s.ariaLabel)}>
                <FooterSocialIcon platform={asStr(s.platform)} />
              </a>
            ))}
          </div>
        </div>
        {footerColumns?.map((col) => (
          <div class="footer-col">
            <p class="footer-heading">{asStr(col.heading)}</p>
            {col.links?.length ? (
              <nav class="footer-links" aria-label={asStr(col.ariaLabel)}>
                {col.links.map((link) => (
                  <a href={asStr(link.href)}>{asStr(link.label)}</a>
                ))}
              </nav>
            ) : null}
            {isContactFooterColumnHeading(col.heading) ? (
              <FooterContactInfo variant="footer-column" phoneTel={phoneTel} phoneDisplay={phoneDisplay} email={email} address={address} addressHref={addressHref} />
            ) : null}
            {col.hoursHeading ? <p class="footer-heading footer-hours-heading">{asStr(col.hoursHeading)}</p> : null}
            {col.hoursText ? <FooterHoursRow hoursText={col.hoursText} /> : null}
          </div>
        ))}
      </div>
    </div>
  </footer>

  <div class="footer-support">
    <div class="container footer-support-inner">
      <p>
        © <span id="year" /> — <a href={copyrightHref}>{companyName}</a>
      </p>
      <nav aria-label={asStr(footerSupport?.ariaLabel)}>
        {footerSupport?.links?.map((link) => (
          <a href={asStr(link.href)} target={asStr(link.target) || undefined} rel={asStr(link.rel) || undefined}>
            {asStr(link.label)}
          </a>
        ))}
      </nav>
    </div>
  </div>
</BaseLayout>
