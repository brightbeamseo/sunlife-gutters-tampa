---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FooterSocialIcon from '../../components/FooterSocialIcon.astro'
import FooterContactInfo from '../../components/FooterContactInfo.astro'
import FooterHoursRow from '../../components/FooterHoursRow.astro'
import { externalLinkAttrs } from '../../lib/external-link.js'
import { googleBusinessProfileUrl, isContactFooterColumnHeading } from '../../lib/footer-contact-heading.js'
import { sanity } from '../../lib/sanity.js'
import { getSiteSettings, getHomePage, mergeHeaderFromSettings } from '../../lib/site-settings.js'
import { asStr, applyTemplate, mediaUrl } from '../../lib/sanity-strings.js'

const serviceAreaFigureSrc =
  'Media (SGT)/Images (SGT)/sunlife-gutters-valrico-fl-two-story-gutter-installation.webp'

let settings = {}
let homePage = {}
let locationPages = []
try {
  ;[settings, homePage, locationPages] = await Promise.all([
    getSiteSettings(),
    getHomePage(),
    sanity.fetch(
      `*[_type == "locationPage" && defined(slug.current)]{
        title,
        headline,
        county,
        countyName,
        "slug": slug.current
      } | order(title asc)`
    ),
  ])
} catch (err) {
  console.warn('[service-area] Sanity fetch failed; using fallback placeholders.', err)
}

const business = settings?.business ?? {}
const header = mergeHeaderFromSettings(settings, homePage?.header)
const footerEstimate = settings?.footerEstimate ?? homePage?.footerEstimate ?? {}
const footerEstimateFields = footerEstimate?.formFields ?? {}
const formsCfg = settings?.forms ?? {}
const footerBrand = settings?.footerBrand ?? homePage?.footerBrand ?? {}
const footerColumns = settings?.footerColumns ?? homePage?.footerColumns ?? []
const footerSupport = settings?.footerSupport ?? homePage?.footerSupport ?? {}

const companyName = asStr(business.companyName) || 'SGT'
const phoneDisplay = asStr(business.phoneDisplay) || '(303) 000-0000'
const phoneTel = asStr(business.phoneTel) || '3030000000'
const email = asStr(business.email) || 'hello@example.com'
const address = asStr(business.addressShort) || 'Tampa, Colorado'
const addressHref = googleBusinessProfileUrl(settings)
const descriptionShort = asStr(business.descriptionShort)
const logoWhite = asStr(business.logoHorizontalWhite)
const logoBlack = asStr(business.logoHorizontalBlack)
const copyrightHref = asStr(business.copyrightSiteUrl) || '#'

const callLabelNav = applyTemplate(asStr(header.callCtaTemplate), { phoneDisplay }) || phoneDisplay
const logoAriaLabel = applyTemplate(asStr(header.logoAriaLabelTemplate), { companyName }) || companyName
const navItems = Array.isArray(header.navItems) ? header.navItems : []
const universalFormAction = asStr(formsCfg?.submitPath) || asStr(footerEstimate?.formAction) || '#'
const universalFormMethod = asStr(footerEstimate?.formMethod) || 'post'
const universalRequiredIndicator = asStr(formsCfg?.requiredIndicator) || '*'

const serviceArea = homePage?.serviceArea ?? {}
const pageTitle = 'Service Area | SGT'
const pageDescription = asStr(serviceArea?.intro) || 'Cities and counties we serve across the Tampa metro.'
const mapEmbedUrl =
  asStr(settings?.mapEmbedUrl) ||
  'https://maps.google.com/maps?q=1502+Lenna+Ave,+Seffner,+FL+33584&t=&z=10&ie=UTF8&iwloc=&output=embed'
const mapIframeTitle =
  applyTemplate(asStr(serviceArea?.mapIframeTitleTemplate), { companyName }) || `${companyName} service area map`

const serviceCities = Array.isArray(serviceArea?.cities) ? serviceArea.cities : []
const locationRows = Array.isArray(locationPages) ? locationPages : []

const countyBySlug = {
  'anna-maria-island-florida': 'Manatee County',
  'apollo-beach-fl': 'Hillsborough County',
  'bradenton-florida': 'Manatee County',
  'brandon-florida': 'Hillsborough County',
  'cortez-florida': 'Manatee County',
  'dade-city-florida': 'Pasco County',
  'dover-florida': 'Hillsborough County',
  'ellenton-florida': 'Manatee County',
  'gibsonton-florida': 'Hillsborough County',
  'gutters-clearwater-fl': 'Pinellas County',
  'gutters-largo-fl': 'Pinellas County',
  'gutters-odessa-fl': 'Hillsborough County',
  'gutters-plant-city-fl': 'Hillsborough County',
  'gutters-riverview-florida': 'Hillsborough County',
  'gutters-ruskin-fl': 'Hillsborough County',
  'gutters-saint-petersburg-fl': 'Pinellas County',
  'gutters-san-antonio-fl': 'Pasco County',
  'gutters-seffner-fl': 'Hillsborough County',
  'gutters-sun-city-center-fl': 'Hillsborough County',
  'gutters-thonotosassa-fl': 'Hillsborough County',
  'gutters-valrico-fl': 'Hillsborough County',
  'gutters-wimauma-fl': 'Hillsborough County',
  'lakewood-ranch-florida': 'Manatee County',
  'land-o-lakes-florida': 'Pasco County',
  'lithia-florida': 'Hillsborough County',
  'longboat-key-florida': 'Sarasota County',
  'lutz-florida': 'Hillsborough County',
  'parrish-florida': 'Manatee County',
  'sarasota-fl': 'Sarasota County',
  'tampa-florida': 'Hillsborough County',
  'wesley-chapel-florida': 'Pasco County',
  'zephyrhills-florida': 'Pasco County',
  'gutters-mulberry-florida': 'Polk County',
}

function slugToCityName(slug) {
  const raw = asStr(slug)
  if (!raw) return ''
  return raw
    .replace(/^gutters-/, '')
    .replace(/-florida$/, '')
    .replace(/-fl$/, '')
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ')
}

function countyForLocation(row) {
  const explicit = asStr(row?.countyName) || asStr(row?.county)
  if (explicit) return explicit
  const slug = asStr(row?.slug)
  return countyBySlug[slug] || ''
}

const cityPages = locationRows
  .map((row) => {
    const slug = asStr(row?.slug)
    const name = slugToCityName(slug) || asStr(row?.title) || asStr(row?.headline)
    if (!slug || !name) return null
    return {
      name,
      href: `/locations/${slug}/`,
      county: countyForLocation(row),
    }
  })
  .filter(Boolean)
  .sort((a, b) => a.name.localeCompare(b.name))

const counties = Array.from(
  new Set(cityPages.map((row) => row.county).filter(Boolean))
).sort((a, b) => a.localeCompare(b))

const cityLinks = cityPages.length > 0 ? cityPages : serviceCities
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  theme={settings?.theme}
  forms={{ submitPath: asStr(settings?.forms?.submitPath) || '/api/lead' }}
>
  <header class="header">
    <div class="offer-bar">
      <div class="offer-bar-inner">
        <p class="offer-message">
          {asStr(header?.offerBar?.textBeforeDiscount)}
          <strong>{asStr(header?.offerBar?.discountLabel)}</strong>
          {asStr(header?.offerBar?.textAfterDiscount)}
          <a href={asStr(header?.offerBar?.ctaHref) || '#contact'} class="offer-link">
            <strong>{asStr(header?.offerBar?.ctaText) || 'Get a Quote Now!'}</strong>
          </a>
        </p>
      </div>
    </div>
    <div class="header-nav">
      <div class="header-inner">
        <a href="/" class="logo" aria-label={logoAriaLabel}>
          {logoBlack ? (
            <img src={mediaUrl(logoBlack)} alt={companyName} class="logo-img" />
          ) : (
            <span class="section-title" style="margin:0; font-size: 1.25rem;">{companyName}</span>
          )}
        </a>
        <button class="nav-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav">
          {navItems.length > 0 ? (
            navItems.map((item, i) => {
              const label = asStr(item.label)
              const href = asStr(item.href)
              const dropdown = item.dropdown
              if (Array.isArray(dropdown) && dropdown.length > 0) {
                const ddId = `service-nav-dd-${i}`
                return (
                  <div class="nav-dropdown" data-nav-dropdown>
                    <button
                      type="button"
                      class="nav-dropdown-toggle"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={ddId}
                      id={`${ddId}-btn`}
                    >
                      {label}
                      <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                    </button>
                    <ul class="nav-dropdown-menu" id={ddId} role="menu">
                      {dropdown.map((link) => (
                        <li role="none">
                          <a href={asStr(link.href)} role="menuitem">
                            {asStr(link.label)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
              return <a href={href || '#'}>{label}</a>
            })
          ) : (
            <>
              <a href="/">Home</a>
              <a href="/services/">Products & Services</a>
            </>
          )}
          <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg">{callLabelNav}</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <section class="section service-area service-area-page" id="service-area">
      <div class="container">
        <div class="why-eyebrow">{asStr(serviceArea?.eyebrow) || 'Service Area'}</div>
        <h1 class="section-title">{asStr(serviceArea?.headline) || 'Areas We Serve'}</h1>
        <p class="section-lead service-area-intro">
          {asStr(serviceArea?.intro) || 'We serve homeowners and businesses throughout the Tampa metro area.'}
        </p>
        <div class="page-split page-split--media-end" style="margin-top: var(--space-xl);">
          <div class="secondary-prose">
            <p>
              Our crews travel from Seffner daily to Tampa, Brandon, Riverview, Clearwater, St. Petersburg, and the surrounding communities listed below. If you are just outside the usual radius—Pasco, southern Polk, or a Gulf beach community—call us anyway; we often extend routes when scheduling allows.
            </p>
            <p>
              Each city page on this site describes local weather patterns, common roof types, and services we recommend for that area. Use them for ideas, then call for a site-specific walkthrough and estimate.
            </p>
          </div>
          <figure class="page-split__media">
            <img
              src={mediaUrl(serviceAreaFigureSrc)}
              alt="Two-story home with new gutters installed in Valrico, Florida"
              width="640"
              height="480"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
        <div class="cities-list">
          <p class="cities-label">{asStr(serviceArea?.citiesLabel) || 'Cities we serve'}</p>
          <nav class="cities-nav" aria-label={asStr(serviceArea?.citiesNavAriaLabel) || 'Cities we serve'}>
            {cityLinks.map((city, i) => (
              <span>
                {i > 0 ? <span aria-hidden="true">, </span> : null}
                <a href={asStr(city?.href)}>{asStr(city?.name)}</a>
              </span>
            ))}
          </nav>
          <p class="cities-label" style="margin-top:1rem;">Counties we cover</p>
          <nav class="cities-nav" aria-label="Counties we serve">
            {counties.map((county, i) => (
              <span>
                {i > 0 ? <span aria-hidden="true">, </span> : null}
                <span>{county}</span>
              </span>
            ))}
          </nav>
        </div>
        <div class="map-wrap" style="margin-top:1.5rem;">
          <iframe
            src={mapEmbedUrl}
            width="600"
            height="420"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={mapIframeTitle}
          ></iframe>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <section id="contact" class="section contact footer-estimate">
      <div class="container">
        <div class="contact-wrapper">
          <div class="contact-info">
            <h2 class="section-title">{asStr(footerEstimate?.headline) || 'Need Gutter Help in Tampa?'}</h2>
            <p>{asStr(footerEstimate?.intro) || 'Contact us for fast service and straightforward estimates.'}</p>
            <FooterContactInfo
              variant="estimate"
              phoneTel={phoneTel}
              phoneDisplay={phoneDisplay}
              email={email}
              address={address}
              addressHref={addressHref}
            />
          </div>
          <form class="contact-form" data-lead-form="service-area-footer" action={universalFormAction} method={universalFormMethod}>
            <div class="contact-form-grid">
              <div class="contact-form-field"><label for="service-area-contact-name">{asStr(footerEstimateFields?.nameLabel) || 'Name'} <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span></label><input id="service-area-contact-name" name="name" type="text" required autocomplete="name" /></div>
              <div class="contact-form-field"><label for="service-area-contact-email">{asStr(footerEstimateFields?.emailLabel) || 'Email'} <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span></label><input id="service-area-contact-email" name="email" type="email" required autocomplete="email" /></div>
              <div class="contact-form-field"><label for="service-area-contact-phone">{asStr(footerEstimateFields?.phoneLabel) || 'Phone'} <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span></label><input id="service-area-contact-phone" name="phone" type="tel" required autocomplete="tel" /></div>
              <div class="contact-form-field"><label for="service-area-contact-location">{asStr(footerEstimateFields?.cityLabel) || 'City'}</label><input id="service-area-contact-location" name="location" type="text" autocomplete="address-level2" /></div>
              <div class="contact-form-field contact-form-field-full"><label for="service-area-contact-message">{asStr(footerEstimateFields?.projectDetailsLabel) || 'Project Details'}</label><textarea id="service-area-contact-message" name="message" rows="4"></textarea></div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">{asStr(footerEstimateFields?.submitButton) || 'Request Quote'}</button>
          </form>
        </div>
      </div>
    </section>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand-block footer-col">
          {logoWhite ? <img src={mediaUrl(logoWhite)} alt={companyName} class="footer-logo" /> : null}
          <p class="footer-address">{descriptionShort}</p>
          <div class="footer-social" aria-label={asStr(footerBrand?.socialAriaLabel)}>
            {footerBrand?.socialLinks?.map((s) => (
              <a href={asStr(s.href)} aria-label={asStr(s.ariaLabel)} {...externalLinkAttrs(asStr(s.href))}>
                <FooterSocialIcon platform={asStr(s.platform)} />
              </a>
            ))}
          </div>
        </div>
        {footerColumns?.map((col) => (
          <div class="footer-col">
            <p class="footer-heading">{asStr(col.heading)}</p>
            {col.links?.length ? (
              <nav class="footer-links" aria-label={asStr(col.ariaLabel)}>
                {col.links.map((link) => (
                  <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
                    {asStr(link.label)}
                  </a>
                ))}
              </nav>
            ) : null}
            {isContactFooterColumnHeading(col.heading) ? (
              <FooterContactInfo
                variant="footer-column"
                phoneTel={phoneTel}
                phoneDisplay={phoneDisplay}
                email={email}
                address={address}
                addressHref={addressHref}
              />
            ) : null}
            {col.hoursHeading ? <p class="footer-heading footer-hours-heading">{asStr(col.hoursHeading)}</p> : null}
            {col.hoursText ? <FooterHoursRow hoursText={col.hoursText} /> : null}
          </div>
        ))}
      </div>
    </div>
  </footer>

  <div class="footer-support">
    <div class="container footer-support-inner">
      <p>
        © <span id="year"></span> —{' '}
        <a href={copyrightHref} {...externalLinkAttrs(copyrightHref)}>
          {companyName}
        </a>
      </p>
      <nav aria-label={asStr(footerSupport?.ariaLabel)}>
        {footerSupport?.links?.map((link) => (
          <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
            {asStr(link.label)}
          </a>
        ))}
      </nav>
    </div>
  </div>
</BaseLayout>
