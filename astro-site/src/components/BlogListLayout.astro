---
/**
 * Inner page shell for /blog/ listing (header, hero+form, slot, footer).
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import FooterSocialIcon from './FooterSocialIcon.astro'
import FooterContactInfo from './FooterContactInfo.astro'
import FooterHoursRow from './FooterHoursRow.astro'
import { googleBusinessProfileUrl, isContactFooterColumnHeading } from '../lib/footer-contact-heading.js'
import { asStr, mediaUrl } from '../lib/sanity-strings.js'

const {
  pageTitle,
  pageDescription,
  theme,
  formsSubmitPath,
  companyName,
  phoneTel,
  phoneDisplay,
  email,
  address,
  addressHref,
  descriptionShort,
  logoWhite,
  logoBlack,
  copyrightHref,
  callLabelNav,
  heroCallLabel,
  logoAriaLabel,
  navItems,
  header,
  footerEstimate,
  footerEstimateFields,
  footerBrand,
  footerColumns,
  footerSupport,
  universalFormFields,
  universalFormAction,
  universalFormMethod,
  universalFormKicker,
  universalFormAriaLabel,
  universalFormHeading,
  universalFormIntro,
  universalRequiredIndicator,
  heroEyebrow,
  heroHeadline,
  heroLead,
  heroBgStyle,
  formIdPrefix,
  navDdPrefix = 'blog',
} = Astro.props
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  theme={theme}
  forms={{ submitPath: formsSubmitPath }}
>
  <header class="header">
    <div class="offer-bar">
      <div class="offer-bar-inner">
        <p class="offer-message">
          {asStr(header?.offerBar?.textBeforeDiscount)}
          <strong>{asStr(header?.offerBar?.discountLabel)}</strong>
          {asStr(header?.offerBar?.textAfterDiscount)}
          <a href={asStr(header?.offerBar?.ctaHref) || '#contact'} class="offer-link">
            <strong>{asStr(header?.offerBar?.ctaText) || 'Get a Quote Now!'}</strong>
          </a>
        </p>
      </div>
    </div>
    <div class="header-nav">
      <div class="header-inner">
        <a href="/" class="logo" aria-label={logoAriaLabel}>
          {logoBlack ? <img src={mediaUrl(logoBlack)} alt={companyName} class="logo-img" /> : <span class="section-title" style="margin:0; font-size: 1.25rem;">{companyName}</span>}
        </a>
        <button class="nav-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav">
          {navItems.length > 0 ? (
            navItems.map((item, i) => {
              const label = asStr(item.label)
              const href = asStr(item.href)
              const dropdown = item.dropdown
              if (Array.isArray(dropdown) && dropdown.length > 0) {
                const ddId = `${navDdPrefix}-nav-dd-${i}`
                return (
                  <div class="nav-dropdown" data-nav-dropdown>
                    <button
                      type="button"
                      class="nav-dropdown-toggle"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={ddId}
                      id={`${ddId}-btn`}
                    >
                      {label}
                      <span class="nav-dropdown-chevron" aria-hidden="true" />
                    </button>
                    <ul class="nav-dropdown-menu" id={ddId} role="menu">
                      {dropdown.map((link) => (
                        <li role="none">
                          <a href={asStr(link.href)} role="menuitem">
                            {asStr(link.label)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
              return <a href={href || '#'}>{label}</a>
            })
          ) : (
            <>
              <a href="/">Home</a>
              <a href="/seamless-gutters/">Products & Services</a>
            </>
          )}
          <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg">{callLabelNav}</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-split">
      <div class="hero-bg" style={heroBgStyle} />
      <div class="container hero-split-inner">
        <div class="hero-copy">
          <div class="hero-eyebrow">{heroEyebrow}</div>
          <h1>{heroHeadline}</h1>
          <p class="hero-lead">{heroLead}</p>
          <div class="hero-actions">
            <a href={`tel:${phoneTel}`} class="btn btn-primary btn-lg cta1-primary-call">{heroCallLabel}</a>
          </div>
        </div>
        <form
          class="hero-form"
          data-lead-form={`${formIdPrefix}-hero`}
          action={universalFormAction}
          method={universalFormMethod}
          aria-label={universalFormAriaLabel}
        >
          <div class="hero-form-heading">
            <div class="hero-form-kicker">{universalFormKicker}</div>
            <h2>{universalFormHeading}</h2>
          </div>
          <p class="hero-form-sub">{universalFormIntro}</p>
          <div class="hero-form-grid">
            <div class="hero-form-field">
              <label for={`${formIdPrefix}-name`}>
                {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${formIdPrefix}-name`} name="name" type="text" required autocomplete="name" />
            </div>
            <div class="hero-form-field">
              <label for={`${formIdPrefix}-email`}>
                {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${formIdPrefix}-email`} name="email" type="email" required autocomplete="email" />
            </div>
            <div class="hero-form-field">
              <label for={`${formIdPrefix}-phone`}>
                {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id={`${formIdPrefix}-phone`} name="phone" type="tel" required autocomplete="tel" />
            </div>
            <div class="hero-form-field">
              <label for={`${formIdPrefix}-location`}>{asStr(universalFormFields?.cityLabel) || 'City'}</label>
              <input id={`${formIdPrefix}-location`} name="location" type="text" autocomplete="address-level2" />
            </div>
            <div class="hero-form-field hero-form-field-full">
              <label for={`${formIdPrefix}-message`}>{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
              <textarea id={`${formIdPrefix}-message`} name="message" rows="3" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">{asStr(universalFormFields?.submitButton) || 'Send'}</button>
        </form>
      </div>
    </section>

    <slot />
  </main>

  <footer class="footer">
    <section id="contact" class="section contact footer-estimate">
      <div class="container">
        <div class="contact-wrapper">
          <div class="contact-info">
            <h2 class="section-title">{asStr(footerEstimate?.headline) || 'Need Gutter Help in Tampa?'}</h2>
            <p>{asStr(footerEstimate?.intro) || 'Contact us for fast service and straightforward estimates.'}</p>
            <FooterContactInfo variant="estimate" phoneTel={phoneTel} phoneDisplay={phoneDisplay} email={email} address={address} addressHref={addressHref} />
          </div>
          <form class="contact-form" data-lead-form={`${formIdPrefix}-footer`} action={universalFormAction} method={universalFormMethod}>
            <div class="contact-form-grid">
              <div class="contact-form-field">
                <label for={`${formIdPrefix}-contact-name`}>
                  {asStr(universalFormFields?.nameLabel) || 'Name'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${formIdPrefix}-contact-name`} name="name" type="text" required autocomplete="name" />
              </div>
              <div class="contact-form-field">
                <label for={`${formIdPrefix}-contact-email`}>
                  {asStr(universalFormFields?.emailLabel) || 'Email'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${formIdPrefix}-contact-email`} name="email" type="email" required autocomplete="email" />
              </div>
              <div class="contact-form-field">
                <label for={`${formIdPrefix}-contact-phone`}>
                  {asStr(universalFormFields?.phoneLabel) || 'Phone'}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input id={`${formIdPrefix}-contact-phone`} name="phone" type="tel" required autocomplete="tel" />
              </div>
              <div class="contact-form-field">
                <label for={`${formIdPrefix}-contact-location`}>{asStr(universalFormFields?.cityLabel) || 'City'}</label>
                <input id={`${formIdPrefix}-contact-location`} name="location" type="text" autocomplete="address-level2" />
              </div>
              <div class="contact-form-field contact-form-field-full">
                <label for={`${formIdPrefix}-contact-message`}>{asStr(universalFormFields?.projectDetailsLabel) || 'Project Details'}</label>
                <textarea id={`${formIdPrefix}-contact-message`} name="message" rows="4" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">{asStr(footerEstimateFields?.submitButton) || 'Request Quote'}</button>
          </form>
        </div>
      </div>
    </section>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand-block footer-col">
          {logoWhite ? <img src={mediaUrl(logoWhite)} alt={companyName} class="footer-logo" /> : null}
          <p class="footer-address">{descriptionShort}</p>
          <div class="footer-social" aria-label={asStr(footerBrand?.socialAriaLabel)}>
            {footerBrand?.socialLinks?.map((s) => (
              <a href={asStr(s.href)} aria-label={asStr(s.ariaLabel)}>
                <FooterSocialIcon platform={asStr(s.platform)} />
              </a>
            ))}
          </div>
        </div>
        {footerColumns?.map((col) => (
          <div class="footer-col">
            <p class="footer-heading">{asStr(col.heading)}</p>
            {col.links?.length ? (
              <nav class="footer-links" aria-label={asStr(col.ariaLabel)}>
                {col.links.map((link) => (
                  <a href={asStr(link.href)}>{asStr(link.label)}</a>
                ))}
              </nav>
            ) : null}
            {isContactFooterColumnHeading(col.heading) ? (
              <FooterContactInfo variant="footer-column" phoneTel={phoneTel} phoneDisplay={phoneDisplay} email={email} address={address} addressHref={addressHref} />
            ) : null}
            {col.hoursHeading ? <p class="footer-heading footer-hours-heading">{asStr(col.hoursHeading)}</p> : null}
            {col.hoursText ? <FooterHoursRow hoursText={col.hoursText} /> : null}
          </div>
        ))}
      </div>
    </div>
  </footer>

  <div class="footer-support">
    <div class="container footer-support-inner">
      <p>
        © <span id="year" /> — <a href={copyrightHref}>{companyName}</a>
      </p>
      <nav aria-label={asStr(footerSupport?.ariaLabel)}>
        {footerSupport?.links?.map((link) => (
          <a href={asStr(link.href)} target={asStr(link.target) || undefined} rel={asStr(link.rel) || undefined}>
            {asStr(link.label)}
          </a>
        ))}
      </nav>
    </div>
  </div>
</BaseLayout>
