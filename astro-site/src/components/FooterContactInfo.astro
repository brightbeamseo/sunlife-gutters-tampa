---
/**
 * Phone / email / address rows with small cyan icons (matches .footer-social accent).
 * - estimate: light “Get estimate” column above the form
 * - footer-column: dark footer “Contact Info” column (matches root index.html)
 */
interface Props {
  variant: 'estimate' | 'footer-column'
  phoneTel: string
  phoneDisplay: string
  email: string
  address: string
  /** Site settings → Business listings → Google Maps (opens in new tab for address) */
  addressHref?: string
}

const { variant, phoneTel, phoneDisplay, email, address, addressHref: addressHrefProp } = Astro.props
const tel = String(phoneTel || '').replace(/\s/g, '')
const addressHref = typeof addressHrefProp === 'string' && addressHrefProp.trim() ? addressHrefProp.trim() : ''
const addressLinkLabel = 'Open address in Google Maps (opens in a new tab)'
---

{variant === 'estimate' ? (
  <div class="contact-details contact-details--with-icons">
    <a class="contact-detail-line" href={`tel:${tel}`}>
      <span class="footer-item-icon" aria-hidden="true">
        <svg class="footer-item-icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>{phoneDisplay}</span>
    </a>
    <a class="contact-detail-line" href={`mailto:${email}`}>
      <span class="footer-item-icon" aria-hidden="true">
        <svg class="footer-item-icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>{email}</span>
    </a>
    {addressHref ? (
      <a
        class="contact-address contact-address-row contact-address--link"
        href={addressHref}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={addressLinkLabel}
      >
        <span class="footer-item-icon" aria-hidden="true">
          <svg class="footer-item-icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22s7-6.3 7-12a7 7 0 1 0-14 0c0 5.7 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{address}</span>
      </a>
    ) : (
      <p class="contact-address contact-address-row">
        <span class="footer-item-icon" aria-hidden="true">
          <svg class="footer-item-icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22s7-6.3 7-12a7 7 0 1 0-14 0c0 5.7 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{address}</span>
      </p>
    )}
  </div>
) : (
  <div class="footer-links footer-contact-list">
    <a href={`tel:${tel}`} class="footer-contact-item">
      <span class="footer-item-icon" aria-hidden="true">
        <svg class="footer-item-icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>{phoneDisplay}</span>
    </a>
    <a href={`mailto:${email}`} class="footer-contact-item">
      <span class="footer-item-icon" aria-hidden="true">
        <svg class="footer-item-icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>{email}</span>
    </a>
    {addressHref ? (
      <a
        href={addressHref}
        class="footer-address footer-contact-item footer-address--link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={addressLinkLabel}
      >
        <span class="footer-item-icon" aria-hidden="true">
          <svg class="footer-item-icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22s7-6.3 7-12a7 7 0 1 0-14 0c0 5.7 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{address}</span>
      </a>
    ) : (
      <p class="footer-address footer-contact-item">
        <span class="footer-item-icon" aria-hidden="true">
          <svg class="footer-item-icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22s7-6.3 7-12a7 7 0 1 0-14 0c0 5.7 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{address}</span>
      </p>
    )}
  </div>
)}
