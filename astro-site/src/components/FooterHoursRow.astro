---
import { asStr } from '../lib/sanity-strings.js'

interface Props {
  hoursText?: unknown
}

const text = asStr(Astro.props.hoursText)
---

{
  text ? (
    <p class="footer-hours footer-contact-item">
      <span class="footer-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="footer-item-icon-svg">
          <path
            d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm1 10.4 3 1.8-1 1.7-4-2.4V7h2Z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>{text}</span>
    </p>
  ) : null
}
